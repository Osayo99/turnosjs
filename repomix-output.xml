                        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></span>
                        En Espera
                    </h3>
                    
                    <div id="listaEspera" class="space-y-3 pr-1 overflow-y-auto flex-grow custom-scrollbar"></div>
                    
                    <div class="mt-4 pt-4 border-t border-white/5 text-center">
