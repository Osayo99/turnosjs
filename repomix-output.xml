<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Monitor de Sala - ANDA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;900&display=swap');
        body { font-family: 'Outfit', sans-serif; overflow: hidden; background: #0f172a; }
        ::-webkit-scrollbar { width: 0px; }
    </style>
</head>
<body class="h-screen text-white relative bg-black">

    <div id="startOverlay" class="absolute inset-0 z-[60] bg-blue-900 flex flex-col items-center justify-center cursor-pointer hover:bg-blue-800 transition-colors">
        <h1 class="text-6xl font-black mb-4 tracking-tighter">ANDA</h1>
        <div class="bg-blue-700 p-4 rounded-full mb-4 animate-pulse">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <p class="text-xl opacity-75 font-bold uppercase tracking-widest">Click para Iniciar Sistema</p>
    </div>

    <button onclick="toggleFullScreen()" class="absolute top-4 right-4 z-50 text-white/20 hover:text-white transition-colors p-2 rounded-lg cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
        </svg>
    </button>

    <div class="flex h-full w-full">
        
        <div class="w-[70%] h-full relative bg-black flex items-center justify-center overflow-hidden">
            
            <div class="absolute top-0 left-0 p-8 z-20 pointer-events-none bg-gradient-to-b from-black/60 to-transparent w-full">
                <h1 class="text-4xl font-black tracking-tighter drop-shadow-lg">ANDA</h1>
                <p id="sucursalName" class="text-sm font-bold text-blue-400 uppercase tracking-widest drop-shadow-md">Cargando...</p>
            </div>

            <video id="tvVideo" class="w-full h-full object-cover opacity-90 transition-opacity duration-1000" autoplay loop muted playsinline>
                <source src="https://videos.pexels.com/video-files/855018/855018-hd_1920_1080_30fps.mp4" type="video/mp4">
            </video>
            
            <div id="callOverlay" class="hidden absolute inset-0 bg-blue-600/95 flex-col items-center justify-center z-30 transition-all duration-300">
                <p class="text-2xl font-bold uppercase tracking-[0.5em] mb-4 text-white animate-fade-in-down">Turno Actual</p>
                <div class="bg-white text-blue-900 px-24 py-12 rounded-[3rem] shadow-2xl mb-8 transform scale-110 border-4 border-blue-300 animate-zoom-in">
                    <h1 id="mainTicket" class="text-[12rem] font-black leading-none tracking-tighter">--</h1>
                </div>
                <div class="flex flex-col items-center gap-2 animate-bounce-slow">
                    <p class="text-2xl text-blue-100 uppercase font-light">Favor pasar a</p>
                    <div class="bg-blue-900 px-10 py-4 rounded-2xl border-2 border-blue-400 shadow-xl">
                        <span class="text-5xl font-bold text-white uppercase" id="mainVentanilla">--</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="w-[30%] bg-slate-900 h-full flex flex-col border-l border-white/10 relative z-10 shadow-2xl">
            
            <div class="absolute inset-0 bg-gradient-to-b from-blue-900/40 to-slate-900 z-0"></div>
            
            <div class="relative z-10 flex flex-col h-full p-6">
                
                <div class="text-right mb-8 pb-4 border-b border-white/10 mt-4">
                    <h2 id="reloj" class="text-5xl font-black text-white tracking-tight">--:--</h2>
                    <p id="fecha" class="text-sm text-blue-300 uppercase font-bold tracking-wider mt-1">--</p>
                </div>

                <div class="bg-white/5 p-6 rounded-2xl border border-white/10 mb-6 text-center shadow-lg backdrop-blur-md">
                    <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2 font-bold">Último Llamado</p>
                    <div class="flex justify-between items-end">
                        <span id="lastTicket" class="text-6xl font-black text-white tracking-tighter leading-none">--</span>
                        <div class="text-right">
                             <span class="block text-[10px] text-gray-500 uppercase">Ventanilla</span>
                             <span id="lastVent" class="text-xl font-bold text-yellow-400 leading-none">--</span>
                        </div>
                    </div>
                </div>

                <div class="flex-grow flex flex-col overflow-hidden">
                    <h3 class="text-xs font-bold uppercase text-blue-400 mb-4 flex items-center gap-2 tracking-widest">
                        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></span>
                        En Espera
                    </h3>
                    
                    <div id="listaEspera" class="space-y-3 pr-1 overflow-y-auto flex-grow custom-scrollbar"></div>
                    
                    <div class="mt-4 pt-4 border-t border-white/5 text-center">
                        <p class="text-[10px] text-white/20 uppercase tracking-widest">Sistema de Atención ANDA</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const sucursalId = localStorage.getItem('anda_sucursal_id');
        let socket = null;
        let voices = [];

        if(!sucursalId) window.location.href = '/';

        window.speechSynthesis.onvoiceschanged = () => {
            voices = window.speechSynthesis.getVoices();
        };

        document.getElementById('startOverlay').addEventListener('click', () => {
            document.getElementById('startOverlay').style.display = 'none';
            toggleFullScreen();
            if(voices.length === 0) voices = window.speechSynthesis.getVoices();
            initSystem();
        });

        function toggleFullScreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(e => console.log(e));
            } else {
                if (document.exitFullscreen) document.exitFullscreen();
            }
        }

        setInterval(() => {
            const now = new Date();
            document.getElementById('reloj').textContent = now.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}).toLowerCase();
            const options = { weekday: 'long', day: 'numeric', month: 'long' };
            document.getElementById('fecha').textContent = now.toLocaleDateString('es-ES', options);
        }, 1000);

        async function initSystem() {
            try {
                const res = await fetch(`/api/sucursales/${sucursalId}`);
                const data = await res.json();
                document.getElementById('sucursalName').textContent = data.nombre;
                const video = document.getElementById('tvVideo');
                if(data.videoUrl) video.src = data.videoUrl;
                video.play().catch(e => console.log("Video autoplay prevented"));
            } catch(e) {}

            actualizarCola();
            socket = io();
            socket.emit('unirse_sucursal', sucursalId);
            socket.on('cola_actualizada', actualizarCola);
            socket.on('ticket_llamado', (t) => {
                mostrarLlamada(t);
                actualizarCola();
            });
            
            socket.on('video_actualizado', (data) => {
                const v = document.getElementById('tvVideo');
                v.src = data.url;
                v.play();
            });
        }

        async function actualizarCola() {
            try {
                const res = await fetch(`/api/tickets/cola/${sucursalId}`);
                const cola = await res.json();
                const cont = document.getElementById('listaEspera');
                cont.innerHTML = '';
                
                if(cola.length === 0) {
                    cont.innerHTML = `
                        <div class="h-full flex flex-col items-center justify-center text-white/20">
                            <svg class="w-8 h-8 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <p class="text-xs italic">Sala vacía</p>
                        </div>`;
                }

                cola.slice(0, 7).forEach(t => { 
                    cont.innerHTML += `
                        <div class="flex justify-between items-center bg-white/5 p-3 rounded-lg border border-white/5 backdrop-blur-sm animate-fade-in hover:bg-white/10 transition-colors group">
                            <span class="text-xl font-bold text-white tracking-wider group-hover:text-blue-300 transition-colors">${t.codigo}</span>
                            <span class="text-[9px] uppercase font-bold text-blue-200 bg-blue-600/20 px-2 py-1 rounded border border-blue-400/20">${t.tipoTramite.substring(0,10)}</span>
                        </div>`;
                });
            } catch(e) {}
        }

        function mostrarLlamada(ticket) {
            const overlay = document.getElementById('callOverlay');
            document.getElementById('mainTicket').textContent = ticket.codigo;
            const numVent = ticket.ventanillaNumero || '?';
            const ventanillaTexto = `Ventanilla ${numVent}`;
            document.getElementById('mainVentanilla').textContent = ventanillaTexto;
            document.getElementById('lastTicket').textContent = ticket.codigo;
            document.getElementById('lastVent').textContent = `V.${numVent}`;
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            setTimeout(() => hablar(ticket.codigo, ventanillaTexto), 500);
            setTimeout(() => { 
                overlay.classList.add('hidden'); 
                overlay.classList.remove('flex'); 
            }, 8000);
        }

        function hablar(codigo, lugar) {
            window.speechSynthesis.cancel();
            const texto = `Ticket ${codigo.replace('-',' ')}, favor pasar a ${lugar}.`;
            const utter = new SpeechSynthesisUtterance(texto);
            const voz = voices.find(v => v.lang.includes('es') && (v.name.includes('Google') || v.name.includes('Female') || v.name.includes('Sabina')));
            if(voz) utter.voice = voz;
            utter.rate = 0.9; 
            window.speechSynthesis.speak(utter);
        }
    </script>
    <style>
        @keyframes fade-in-down { 0% { opacity: 0; transform: translateY(-20px); } 100% { opacity: 1; transform: translateY(0); } }
        @keyframes zoom-in { 0% { opacity: 0; transform: scale(0.5); } 100% { opacity: 1; transform: scale(1.1); } }
        .animate-fade-in-down { animation: fade-in-down 0.5s ease-out; }
        .animate-zoom-in { animation: zoom-in 0.5s ease-out forwards; }
        .animate-fade-in { animation: fade-in-down 0.3s ease-out; }
    </style>
</body>
</html>
</file>

