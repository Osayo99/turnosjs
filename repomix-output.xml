            <div class="space-y-4">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">URL de Webhook (Apps Script)</label>
                    <input type="text" id="confSheetId" placeholder="https://script.google.com/macros/s/..." class="w-full p-3 bg-gray-900 border border-gray-600 rounded-xl text-white text-xs outline-none focus:border-blue-500">
                    <p class="text-[10px] text-gray-500 mt-1">Pegue la URL generada al implementar la App Web.</p>
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-1">Frecuencia de Envío</label>
                    <select id="confFreq" class="w-full p-3 bg-gray-900 border border-gray-600 rounded-xl text-white text-sm outline-none focus:border-blue-500">
                        <option value="none">Desactivado</option>
                        <option value="1h">Cada Hora</option>
                        <option value="24h">Diariamente (11:00 PM)</option>
                        <option value="7d">Semanalmente (Domingo)</option>
                    </select>
                </div>
            </div>
            <div class="flex gap-3 justify-end mt-6">
                <button onclick="document.getElementById('modalSheet').classList.add('hidden')" class="text-gray-400 font-bold text-sm px-4">Cancelar</button>
                <button onclick="guardarConfigSheet()" class="bg-green-600 text-white px-6 py-2 rounded-xl font-bold text-sm hover:bg-green-500">Guardar</button>
            </div>
        </div>
    </div>

    <div id="modalGuia" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-gray-800 p-6 rounded-2xl shadow-xl w-full max-w-lg border border-gray-600">
            <h3 id="modalGuiaTitle" class="font-bold text-lg text-white mb-4">📚 Crear Guía de Procedimiento</h3>
            
            <input type="hidden" id="guiaIdEdit">

            <div class="space-y-4">
                <input type="text" id="guiaTitulo" placeholder="Título (Ej: Pago de Facturas Vencidas)" class="w-full p-3 bg-gray-900 border border-gray-600 rounded-xl text-white text-sm outline-none focus:border-yellow-500">
                <textarea id="guiaContenido" rows="5" placeholder="Describa el procedimiento paso a paso..." class="w-full p-3 bg-gray-900 border border-gray-600 rounded-xl text-white text-sm outline-none focus:border-yellow-500"></textarea>
            </div>
            <div class="flex gap-3 justify-end mt-6">
                <button onclick="document.getElementById('modalGuia').classList.add('hidden')" class="text-gray-400 font-bold text-sm">Cancelar</button>
                <button id="btnGuardarGuia" onclick="guardarGuia()" class="bg-yellow-600 text-white px-6 py-2 rounded-xl font-bold text-sm hover:bg-yellow-500">Publicar</button>
            </div>
        </div>
    </div>

    <div id="modalMiClave" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-gray-800 w-full max-w-sm p-6 rounded-2xl shadow-2xl border border-gray-600">
            <h3 class="text-lg font-bold text-white mb-4">Cambiar Mi Contraseña</h3>
            <div class="space-y-3"><input type="password" id="myOldPass" placeholder="Actual" class="w-full p-3 bg-gray-900 border border-gray-600 rounded-xl text-white"><input type="password" id="myNewPass" placeholder="Nueva" class="w-full p-3 bg-gray-900 border border-gray-600 rounded-xl text-white"></div>
            <div class="flex gap-3 justify-end mt-6"><button onclick="document.getElementById('modalMiClave').classList.add('hidden')" class="text-gray-400 font-bold text-sm px-4">Cancelar</button><button onclick="guardarMiClave()" class="bg-blue-600 text-white px-6 py-2 rounded-xl font-bold text-sm hover:bg-blue-500">Guardar</button></div>
        </div>
    </div>

    <script>
        let currentSucursalId = null, allUsersCache = [], allSucursalesCache = [], currentUserData = null;

        (function checkSession() {
            const storedUser = localStorage.getItem('anda_session_admin');
            if (storedUser) {
                currentUserData = JSON.parse(storedUser);
                document.getElementById('loginView').classList.add('hidden');
                document.getElementById('mainView').classList.remove('hidden');
                document.getElementById('currentAdminName').textContent = currentUserData.nombre;
                cargarGlobal();
            }
        })();

        function toggleRegister() { document.getElementById('formLogin').classList.toggle('hidden'); document.getElementById('formRegister').classList.toggle('hidden'); }
        
        async function loginAdmin() { 
            const u = document.getElementById('adminUser').value;
            const p = document.getElementById('adminPass').value; 
            
            if(!u||!p) return alert("Datos incompletos"); 
            
            try { 
                const r = await fetch('/api/usuarios/login',{
                    method:'POST',
                    headers:{'Content-Type':'application/json'},
                    body:JSON.stringify({username:u,password:p})
                }); 
                const d = await r.json(); 
                
                if(d.success && d.user.rol === 'super_admin'){ 
                    currentUserData = d.user;
                    localStorage.setItem('anda_session_admin', JSON.stringify(d.user));

                    document.getElementById('loginView').classList.add('hidden'); 
                    document.getElementById('mainView').classList.remove('hidden'); 
                    document.getElementById('currentAdminName').textContent = d.user.nombre; 
                    cargarGlobal(); 
                } else {
                    alert("Acceso denegado"); 
                }
            } catch(e){ alert("Error de conexión"); } 
        }

        function logout() { 
            localStorage.removeItem('anda_session_admin');
            location.reload(); 
        }

        async function cargarGlobal() {
            const r = await fetch('/api/admin/global-data'); 
            const d = await r.json(); 
            
            allSucursalesCache = d.sucursales; 
            allUsersCache = d.usuarios; 
            document.getElementById('countSucursales').textContent = d.sucursales.length;
            
            const ls = document.getElementById('listaSucursales');
            const sel = document.getElementById('newJefeSucursal'); 
            
            ls.innerHTML = ''; 
            sel.innerHTML = '<option value="">Seleccione Sucursal...</option>';
            
            d.sucursales.forEach(s => {
                ls.innerHTML += `
                <div class="group flex justify-between items-center bg-gray-700/30 p-4 rounded-xl border border-transparent hover:border-blue-500 transition-all mb-2">
                    <div onclick="entrarSucursal('${s._id}', '${s.nombre}')" class="cursor-pointer flex-grow">
                        <p class="font-bold text-white group-hover:text-blue-400 text-sm">${s.nombre}</p>
                        <p class="text-[10px] text-gray-500 uppercase tracking-wider">${s.codigo}</p>
                    </div>
                    <div class="flex gap-2 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity">
                        <button onclick="abrirConfigSheet('${s._id}', '${s.googleSheetId||''}', '${s.frecuenciaExportacion||'none'}')" class="text-green-500 hover:text-green-300 text-xs font-bold bg-green-900/20 px-2 py-1 rounded" title="Reportes">📊</button>
                        <button onclick="abrirModalEditarSucursal('${s._id}', '${s.nombre}', '${s.codigo}', '${s.direccion || ''}')" class="text-blue-400 hover:text-blue-300 text-xs font-bold bg-blue-900/20 px-2 py-1 rounded" title="Editar">✏️</button>
                        <button onclick="eliminarSucursalFront('${s._id}')" class="text-red-400 hover:text-red-300 text-xs font-bold bg-red-900/20 px-2 py-1 rounded" title="Eliminar">🗑️</button>
                    </div>
                </div>`;
                
                sel.innerHTML += `<option value="${s._id}">${s.nombre}</option>`;
            });
            
            renderUsers(allUsersCache);
            cargarGuiasAdmin();
        }

        async function cargarGuiasAdmin() {
            try {
                const res = await fetch('/api/guias');
                const guias = await res.json();
                const container = document.getElementById('listaGuiasAdmin');
                
                if(guias.length === 0) {
                    container.innerHTML = '<p class="text-gray-500 text-sm col-span-full">No hay guías creadas.</p>';
                    return;
                }

                container.innerHTML = guias.map(g => `
                    <div class="bg-gray-700/50 p-4 rounded-xl border border-gray-600 relative group min-h-[100px] flex flex-col hover:border-blue-500 transition-colors">
                        <h4 class="font-bold text-white text-sm mb-2 pr-16">${g.titulo}</h4>
                        <p class="text-xs text-gray-400 line-clamp-3 flex-grow">${g.contenido}</p>
                        <div class="absolute top-2 right-2 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button onclick="prepararEdicion('${g._id}', '${escapeHtml(g.titulo)}', '${escapeHtml(g.contenido)}')" class="bg-blue-600 hover:bg-blue-500 text-white rounded p-1.5" title="Editar">✏️</button>
                            <button onclick="borrarGuia('${g._id}')" class="bg-red-600 hover:bg-red-500 text-white rounded p-1.5" title="Eliminar">🗑️</button>
                        </div>
                    </div>
                `).join('');
            } catch(e) { console.error(e); }
        }

        function prepararEdicion(id, titulo, contenido) {
            document.getElementById('guiaIdEdit').value = id;
            document.getElementById('guiaTitulo').value = titulo;
            document.getElementById('guiaContenido').value = contenido;
            document.getElementById('modalGuiaTitle').textContent = "✏️ Editar Guía";
            document.getElementById('btnGuardarGuia').textContent = "Actualizar";
            document.getElementById('modalGuia').classList.remove('hidden');
        }

        function abrirModalNuevaGuia() {
            document.getElementById('guiaIdEdit').value = ""; 
            document.getElementById('guiaTitulo').value = "";
            document.getElementById('guiaContenido').value = "";
            document.getElementById('modalGuiaTitle').textContent = "📚 Nueva Guía";
            document.getElementById('btnGuardarGuia').textContent = "Publicar";
            document.getElementById('modalGuia').classList.remove('hidden');
        }

        async function guardarGuia() {
            const id = document.getElementById('guiaIdEdit').value;
            const titulo = document.getElementById('guiaTitulo').value;
            const contenido = document.getElementById('guiaContenido').value;
            if(!titulo || !contenido) return alert("Complete ambos campos");
            const url = id ? `/api/guias/${id}` : '/api/guias';
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await fetch(url, { method: method, headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ titulo, contenido }) });
                if(res.ok) { document.getElementById('modalGuia').classList.add('hidden'); cargarGuiasAdmin(); } else { alert("Error al guardar"); }
            } catch(e) { alert("Error de conexión"); }
        }

        async function borrarGuia(id) { if(confirm('¿Borrar esta guía permanentemente?')) { await fetch(`/api/guias/${id}`, { method: 'DELETE' }); cargarGuiasAdmin(); } }
        function escapeHtml(text) { if (!text) return ""; return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;").replace(/\n/g, "\\n"); }

        function abrirModalCrearSucursal() { document.getElementById('modalNewSucursal').classList.remove('hidden'); }
        async function guardarNuevaSucursal() {
            const nombre = document.getElementById('crearSucName').value;
            const codigo = document.getElementById('crearSucCode').value;
            const direccion = document.getElementById('crearSucDir').value;
            if(!nombre || !codigo) return alert("Nombre y Código son obligatorios");
            try {
                const res = await fetch('/api/sucursales', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ nombre, codigo, direccion }) });
                const data = await res.json();
                if(data._id) { alert("✅ Agencia creada exitosamente"); document.getElementById('modalNewSucursal').classList.add('hidden'); document.getElementById('crearSucName').value = ''; document.getElementById('crearSucCode').value = ''; document.getElementById('crearSucDir').value = ''; cargarGlobal(); } else { alert("Error al crear agencia"); }
            } catch(e) { alert("Error de conexión"); }
        }

        function abrirModalEditarSucursal(id, nombre, codigo, direccion) {
            document.getElementById('editSucId').value = id;
            document.getElementById('editSucName').value = nombre;
            document.getElementById('editSucCode').value = codigo;
            document.getElementById('editSucDir').value = direccion;
            document.getElementById('modalEditSucursal').classList.remove('hidden');
        }

        async function guardarEdicionSucursal() {
            const id = document.getElementById('editSucId').value;
            const nombre = document.getElementById('editSucName').value;
            const codigo = document.getElementById('editSucCode').value;
            const direccion = document.getElementById('editSucDir').value;

            if(!nombre || !codigo) return alert("⚠️ El Nombre y Código son obligatorios");

            try {
                const res = await fetch(`/api/sucursales/${id}`, { 
                    method: 'PUT', 
                    headers: {'Content-Type': 'application/json'}, 
                    body: JSON.stringify({ nombre, codigo, direccion }) 
                });
                const data = await res.json();
                
                if(data.success) { 
                    alert("✅ Agencia actualizada correctamente"); 
                    document.getElementById('modalEditSucursal').classList.add('hidden'); 
                    cargarGlobal(); 
                } else { 
                    alert("❌ " + (data.msg || "Error al actualizar")); 
                }
            } catch(e) { 
                alert("❌ Error de comunicación con el servidor"); 
            }
        }

        async function eliminarSucursalFront(id) {
            if(confirm('⚠️ ¿Estás completamente seguro de eliminar esta agencia?\n\nEsto podría afectar el historial si hay tickets enlazados a ella.')) {
                try {
                    const res = await fetch(`/api/sucursales/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    
                    if(data.success) {
                        alert("✅ Agencia eliminada exitosamente");
                        cargarGlobal();
                    } else {
                        alert("❌ " + (data.msg || "Error al eliminar la agencia"));
                    }
                } catch(e) {
                    alert("❌ Error de comunicación con el servidor");
                }
            }
        }

        function renderUsers(users) { 
            const container = document.getElementById('listaUsuariosGlobal');
            
            if (users.length) {
                container.innerHTML = users.map(u => `
                    <tr class="hover:bg-gray-700/50 border-b border-gray-700 last:border-0 transition-colors">
                        <td class="p-4 font-medium text-white">
                            ${u.nombre}
                            <div class="text-xs text-gray-500">@${u.username}</div>
                        </td>
                        <td class="p-4">
                            <span class="bg-gray-700 px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider">
                                ${u.rol.replace('_',' ')}
                            </span>
                        </td>
                        <td class="p-4 text-xs text-gray-400">
                            ${u.sucursal ? u.sucursal.nombre : 'Global'}
                        </td>
                        <td class="p-4 text-right flex justify-end gap-2">
                            <button onclick="abrirModalEditarUsuario('${u._id}', '${u.nombre}', '${u.username}', '${u.rol}', '${u.sucursal ? u.sucursal._id : ''}')" class="text-blue-400 hover:text-white px-2 py-1 rounded text-xs font-bold" title="Editar Usuario">✏️</button>
                            <button onclick="resetUserPass('${u._id}', '${u.nombre}')" class="text-yellow-400 hover:text-white px-2 py-1 rounded text-xs font-bold" title="Resetear Clave">🔑</button>
                            <button onclick="eliminar('${u._id}')" class="text-red-400 hover:text-white px-2 py-1 rounded text-xs font-bold" title="Eliminar Usuario">🗑️</button>
                        </td>
                    </tr>
                `).join('');
            } else {
                container.innerHTML = '<tr><td colspan="4" class="p-4 text-center">Vacío.</td></tr>';
            }
        }

        function abrirModalEditarUsuario(id, nombre, username, rol, sucursalId) {
            document.getElementById('editUserId').value = id;
            document.getElementById('editUserNombre').value = nombre;
            document.getElementById('editUserUsername').value = username;
            document.getElementById('editUserRol').value = rol;
            
            const selSucursal = document.getElementById('editUserSucursal');
            selSucursal.innerHTML = '<option value="">Global / Sin sucursal</option>';
            allSucursalesCache.forEach(s => {
                selSucursal.innerHTML += `<option value="${s._id}">${s.nombre}</option>`;
            });
            
            document.getElementById('editUserSucursal').value = sucursalId || '';
            document.getElementById('modalEditUsuario').classList.remove('hidden');
        }

        async function guardarEdicionUsuario() {
            const id = document.getElementById('editUserId').value;
            const nombre = document.getElementById('editUserNombre').value;
            const username = document.getElementById('editUserUsername').value;
            const rol = document.getElementById('editUserRol').value;
            const sucursalId = document.getElementById('editUserSucursal').value;

            if(!nombre || !username) return alert("⚠️ Nombre y Usuario son obligatorios");

            try {
                const r = await fetch('/api/admin/editar-usuario', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, nombre, username, rol, sucursalId: sucursalId || null })
                });
                
                const d = await r.json();
                
                if(d.success) {
                    alert("✅ " + d.msg);
                    document.getElementById('modalEditUsuario').classList.add('hidden');
                    cargarGlobal();
                } else {
                    alert("❌ Falló: " + (d.msg || "Error desconocido."));
                }
            } catch(e) {
                alert("❌ Error de comunicación con el servidor.");
                console.error(e);
            }
        }
        
        async function crearJefe() { 
            const s = document.getElementById('newJefeSucursal').value;
            const n = document.getElementById('newJefeNombre').value;
            const u = document.getElementById('newJefeUser').value;
            const p = document.getElementById('newJefePass').value; 

            if (!s || !n || !u || !p) {
                return alert("⚠️ Faltan datos por completar."); 
            }

            try {
                const r = await fetch('/api/admin/crear-usuario', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        sucursalId: s, 
                        nombre: n, 
                        username: u, 
                        password: p, 
                        rol: 'jefe_sucursal' 
                    })
                });
                
                if (!r.headers.get('content-type')?.includes('application/json')) {
                    throw new Error("El servidor no respondió con JSON válido.");
                }

                const d = await r.json(); 

                if (d.success) {
                    alert("✅ " + d.msg);
                    document.getElementById('newJefeNombre').value = '';
                    document.getElementById('newJefeUser').value = '';
                    document.getElementById('newJefePass').value = '';
                    document.getElementById('newJefeSucursal').value = '';
                    cargarGlobal();
                } else {
                    alert("❌ Falló: " + (d.msg || "Error desconocido al crear."));
                }
            } catch (error) {
                alert("❌ Error de comunicación con el servidor.");
                console.error("Error en crearJefe:", error);
            }
        }

        function abrirConfigSheet(id, sid, f) { 
            document.getElementById('modalSheet').classList.remove('hidden'); 
            document.getElementById('confSucursalId').value = id; 
            document.getElementById('confSheetId').value = sid; 
            document.getElementById('confFreq').value = f; 
        }

        async function guardarConfigSheet() { 
            const id = document.getElementById('confSucursalId').value;
            const s = document.getElementById('confSheetId').value;
            const f = document.getElementById('confFreq').value; 

            try {
                const r = await fetch('/api/admin/config-export', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sucursalId: id, sheetId: s, frecuencia: f })
                });
                
                const d = await r.json();
                
                if (d.success) {
                    alert("Configuración Guardada");
                    document.getElementById('modalSheet').classList.add('hidden');
                    cargarGlobal();
                } else {
                    alert("Error al guardar la configuración");
                }
            } catch (e) {
                alert("Error de red");
                console.error(e);
            }
        }

        function verGlobal() { 
            document.getElementById('viewBranch').classList.add('hidden'); 
            document.getElementById('viewGlobal').classList.remove('hidden'); 
            document.getElementById('breadCrumb').classList.add('hidden'); 
            currentSucursalId = null; 
        }

        async function entrarSucursal(id, n) { 
            currentSucursalId = id; 
            document.getElementById('viewGlobal').classList.add('hidden'); 
            document.getElementById('viewBranch').classList.remove('hidden'); 
            document.getElementById('breadCrumb').classList.remove('hidden'); 
            document.getElementById('bcSucursalName').textContent = n; 
            document.getElementById('searchBranchQuery').value = ""; 
            document.getElementById('dateStart').value = ""; 
            document.getElementById('dateEnd').value = ""; 
            document.getElementById('listaTicketsBranch').innerHTML = `
                <tr><td colspan="6" class="p-12 text-center text-gray-500 italic">Filtre para ver datos.</td></tr>
            `; 
        }

        async function buscarEnSucursal() { 
            if (!currentSucursalId) return; 
            
            const q = document.getElementById('searchBranchQuery').value;
            const s = document.getElementById('dateStart').value;
            const e = document.getElementById('dateEnd').value;
            const tb = document.getElementById('listaTicketsBranch'); 
            
            tb.innerHTML = `<tr><td colspan="6" class="p-12 text-center text-gray-500 animate-pulse">Buscando...</td></tr>`; 
            
            try { 
                const r = await fetch(`/api/admin/sucursal/${currentSucursalId}?busqueda=${q}&fechaInicio=${s}&fechaFin=${e}`); 
                const d = await r.json(); 
                
                document.getElementById('brTotal').textContent = d.stats.total; 
                document.getElementById('brAtendidos').textContent = d.stats.atendidos; 
                document.getElementById('brJefatura').textContent = d.stats.atendidosJefatura; 
                
                if (!d.registros.length) {
                    tb.innerHTML = `<tr><td colspan="6" class="p-12 text-center text-gray-500 italic">Sin resultados.</td></tr>`;
                } else {
                    tb.innerHTML = d.registros.map(t => `
                        <tr class="hover:bg-gray-700/30 border-b border-gray-700 last:border-0 transition-colors">
                            <td class="p-4">
                                <span class="font-bold text-xl text-white">${t.codigo}</span>
                                <div class="text-[10px] text-gray-500">${t.tipoTramite}</div>
                            </td>
                            <td class="p-4 text-xs text-gray-400 font-mono">
                                ${new Date(t.creadoEn).toLocaleString()}
                            </td>
                            <td class="p-4 text-sm text-blue-300">
                                ${t.documentoCliente || 'N/A'}
                            </td>
                            <td class="p-4 text-xs text-gray-300">
                                ${t.ventanillaAtendio?.nombre || 'Pendiente'}
                            </td>
                            <td class="p-4 text-sm break-words">
                                ${t.notasAtencion || '--'}
                            </td>
                            <td class="p-4 text-center font-mono text-yellow-400 text-sm">
                                ${formatearTiempo(t.tiempoTotalAtencion)}
                            </td>
                            <td class="p-4 text-right">
                                <span class="px-2 py-1 rounded text-[10px] font-bold ${t.estado === 'finalizado' ? 'text-green-400 bg-green-900/20' : 'text-yellow-400 bg-yellow-900/20'}">
                                    ${t.estado}
                                </span>
                            </td>
                        </tr>
                    `).join('');
                }
            } catch(e) {
                console.error("Error buscando en sucursal:", e);
                tb.innerHTML = `<tr><td colspan="6" class="p-12 text-center text-red-500 italic">Error al buscar.</td></tr>`;
            } 
        }

        document.getElementById('searchUserGlobal').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            const filtrados = allUsersCache.filter(u => 
                u.nombre.toLowerCase().includes(term) || u.username.toLowerCase().includes(term)
            );
            renderUsers(filtrados);
        });

        async function resetUserPass(id, n) { 
            const p = prompt(`Nueva clave para ${n}:`); 
            if (!p) return;
            
            try {
                const r = await fetch('/api/usuarios/admin-reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ targetUserId: id, nuevaPassword: p })
                });
                
                if (r.ok) {
                    alert("✅ Clave actualizada correctamente.");
                } else {
                    alert("❌ Error al actualizar clave.");
                }
            } catch(e) {
                console.error(e);
            }
        }

        async function eliminar(id) { 
            if (confirm("¿Estás seguro de que deseas eliminar este usuario?")) {
                try {
                    await fetch('/api/admin/eliminar-usuario', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });
                    cargarGlobal();
                } catch(e) {
                    console.error(e);
                }
            } 
        }

        function abrirModalMiClave() { 
            document.getElementById('modalMiClave').classList.remove('hidden'); 
        }

        async function guardarMiClave() { 
            const o = document.getElementById('myOldPass').value;
            const n = document.getElementById('myNewPass').value; 
            
            try {
                const r = await fetch('/api/usuarios/cambiar-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ usuarioId: currentUserData._id, actual: o, nueva: n })
                });
                
                const d = await r.json();
                
                if (d.success) {
                    alert("✅ Contraseña cambiada correctamente.");
                    document.getElementById('modalMiClave').classList.add('hidden');
                    document.getElementById('myOldPass').value = '';
                    document.getElementById('myNewPass').value = '';
                } else {
                    alert("❌ " + d.msg);
                }
            } catch(e) {
                console.error(e);
                alert("Error de conexión");
            }
        }
        function formatearTiempo(segundos) {
            if (!segundos) return "--:--";
            const m = Math.floor(segundos / 60).toString().padStart(2, '0');
            const s = (segundos % 60).toString().padStart(2, '0');
            return `${m}:${s}`;
        }
    </script>
</body>
</html>
</file>

