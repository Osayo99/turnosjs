<script>

    const sucursalId = localStorage.getItem('anda_sucursal_id');
    let currentUser = null;
    let currentTicketId = null;
    let socket = null;
    let timerInterval = null;
    let secondsElapsed = 0;


    if(!sucursalId) window.location.href = '/';


    (async function initSystem() {

        document.getElementById('loginView').classList.add('hidden');
        document.getElementById('dashboardView').classList.add('hidden');

        try {
            const res = await fetch(`/api/sucursales/${sucursalId}`);
            const data = await res.json();
            document.getElementById('sucursalDisplay').textContent = data.nombre;
        } catch(e) {}

        const storedUser = localStorage.getItem('anda_session_ventanilla');
        
        if (storedUser) {
            currentUser = JSON.parse(storedUser);
            await restaurarSesion();
        } else {
            document.getElementById('loginView').classList.remove('hidden');
        }
    })();
-
    async function restaurarSesion() {

        document.getElementById('userInfo').classList.remove('hidden');
        document.getElementById('userNameDisplay').textContent = currentUser.nombre;

        if (!socket) {
            socket = io();
            socket.emit('unirse_sucursal', sucursalId);
        }

        cargarGuiasVentanilla();

        try {
            const res = await fetch(`/api/tickets/activo/${currentUser._id}`);
            const data = await res.json();
            document.getElementById('dashboardView').classList.remove('hidden');
            document.getElementById('dashboardView').classList.add('grid');

            if (data.success && data.ticket) {
                console.log("Recuperando ticket:", data.ticket.codigo);
                const fechaBase = data.ticket.actualizadoEn || data.ticket.creadoEn;
                const inicio = new Date(fechaBase).getTime();
                const ahora = new Date().getTime();
                let diffSegundos = 0;
                if (!isNaN(inicio)) {
                    diffSegundos = Math.floor((ahora - inicio) / 1000);
                }
                if (diffSegundos < 0) diffSegundos = 0;
                startSessionUI(data.ticket, diffSegundos);
            } else {
                mostrarEstadoLibre();
            }
        } catch (error) {
            console.error("Error recuperando estado:", error);
            mostrarEstadoLibre(); 
        }
    }
    function cargarGuiasVentanilla() {
        fetch('/api/guias')
            .then(res => res.json())
            .then(guias => {
                const container = document.getElementById('knowledgeList');
                
                if(guias.length === 0) {
                    container.innerHTML = '<div class="text-center p-4"><p class="text-xs text-gray-400">Sin guías publicadas.</p></div>';
                    return;
                }
                container.innerHTML = guias.map(g => `
                    <div onclick="abrirPopupGuia('${escapeHtml(g.titulo)}', '${escapeHtml(g.contenido)}')" 
                         class="bg-white p-4 rounded-xl border border-blue-100 shadow-sm cursor-pointer hover:shadow-md hover:border-blue-400 hover:-translate-x-1 transition-all group select-none relative overflow-hidden mb-3">
                        
                        <div class="absolute right-0 top-0 w-1 h-full bg-blue-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        
                        <div class="flex justify-between items-center mb-1">
                            <h4 class="font-bold text-blue-800 text-sm leading-tight group-hover:text-blue-600">${g.titulo}</h4>
                            <span class="text-xs text-blue-300">↗</span>
                        </div>
                        
                        <p class="text-[10px] text-gray-400 line-clamp-2">${g.contenido.substring(0, 80)}...</p>
                    </div>
                `).join('');
            });
    }

    function abrirPopupGuia(titulo, contenido) {
        document.getElementById('popupTitulo').textContent = titulo;
        document.getElementById('popupContenido').textContent = contenido;
        document.getElementById('modalLeerGuia').classList.remove('hidden');
    }
    async function login(){
        const u = document.getElementById('loginUser').value;
        const p = document.getElementById('loginPass').value;
        if(!u || !p) return alert("Credenciales incompletas");

        try {
            const res = await fetch('/api/usuarios/login', {
                method:'POST', 
                headers:{'Content-Type':'application/json'}, 
                body:JSON.stringify({ username: u, password: p, sucursalId })
            });
            const d = await res.json();
            
            if(d.success){ 
                if(d.user.rol === 'jefe_sucursal') {
                    sessionStorage.setItem('anda_user', JSON.stringify(d.user));
                    window.location.href = '/jefatura.html';
                } else {
                    currentUser = d.user; 
                    localStorage.setItem('anda_session_ventanilla', JSON.stringify(d.user));
                    window.location.reload(); 
                }
            } else {
                alert(d.msg);
            }
        } catch(e) { alert("Error de conexión"); }
    }

    function logout(){ 
        localStorage.removeItem('anda_session_ventanilla');
        window.location.reload(); 
    }

    async function llamarSiguiente() {
        const btn = document.querySelector('button[onclick="llamarSiguiente()"]');
        btn.disabled = true; 
        btn.innerHTML = "⏳ Verificando...";
        
        try {
            const res = await fetch('/api/tickets/llamar', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ sucursalId, usuarioId: currentUser._id, ventanilla: currentUser.numeroVentanilla })
            });
            const data = await res.json();
            
            if(data.success) {
                if(data.restored) {
                    const fechaBase = data.ticket.actualizadoEn || data.ticket.creadoEn;
                    const inicio = new Date(fechaBase).getTime();
                    let diff = Math.floor((new Date().getTime() - inicio) / 1000);
                    if(diff < 0) diff = 0;
                    startSessionUI(data.ticket, diff);
                } else {
                    startSessionUI(data.ticket, 0);
                }
            } else {
                alert(data.msg);
            }
        } catch(e) { console.error(e); }
        
        btn.disabled = false; 
        btn.innerHTML = "🔔 LLAMAR SIGUIENTE";
    }

    async function finalizarAtencion() {
        if(!confirm("¿Finalizar atención?")) return;
        const notas = document.getElementById('notasInput').value;
        try {
            const res = await fetch('/api/tickets/finalizar', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ ticketId: currentTicketId, notas, tiempoTotal: secondsElapsed })
            });
            if(res.ok) mostrarEstadoLibre();
        } catch(e) { alert("Error de conexión"); }
    }

    async function volverALlamar() {
        const btn = document.querySelector('button[onclick="volverALlamar()"]');
        btn.disabled = true; btn.classList.add('opacity-50');

        await fetch('/api/tickets/volver-llamar', {
            method: 'POST', headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ sucursalId, usuarioId: currentUser._id })
        });

        if(timerInterval) clearInterval(timerInterval);
        const display = document.getElementById('timerDisplay');
        const savedTime = display.textContent;
        display.textContent = "LLEGANDO...";
        display.classList.add('blink');
        
        setTimeout(() => {
            display.classList.remove('blink');
            display.textContent = savedTime;
            startTimer(); 
        }, 5000);
        setTimeout(() => { btn.disabled = false; btn.classList.remove('opacity-50'); }, 1000);
    }

    function startSessionUI(ticket, segundosIniciales) {
        currentTicketId = ticket._id;
        
        document.getElementById('stateWaiting').classList.add('hidden');
        document.getElementById('stateWaiting').classList.remove('flex');
        document.getElementById('stateActive').classList.remove('hidden');
        document.getElementById('stateActive').classList.add('flex');
        document.getElementById('workspacePanel').classList.remove('hidden');
        document.getElementById('workspacePanel').classList.add('flex');

        document.getElementById('currentTicket').textContent = ticket.codigo;
        document.getElementById('currentTramite').textContent = ticket.tipoTramite;
        document.getElementById('clientDuiDisplay').textContent = `DUI: ${ticket.documentoCliente || '---'}`;
        
        if(ticket.esPrioritario) {
            document.getElementById('prioBadge').classList.remove('hidden');
            document.getElementById('prioBadge').textContent = `★ ${ticket.condicionesEspeciales.join(', ')}`;
        } else {
            document.getElementById('prioBadge').classList.add('hidden');
        }

        secondsElapsed = segundosIniciales;
        actualizarRelojVisual();
        
        if (timerInterval) clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            secondsElapsed++;
            actualizarRelojVisual();
        }, 1000);
        
        if(segundosIniciales < 5) {
            const tDisplay = document.getElementById('timerDisplay');
            tDisplay.textContent = "LLEGANDO..."; 
            tDisplay.classList.add('blink');
            setTimeout(() => { 
                tDisplay.classList.remove('blink'); 
                actualizarRelojVisual(); 
            }, 4000);
        }
    }

    function mostrarEstadoLibre() {
        if (timerInterval) clearInterval(timerInterval);
        currentTicketId = null;
        document.getElementById('stateActive').classList.add('hidden');
        document.getElementById('stateActive').classList.remove('flex');
        document.getElementById('workspacePanel').classList.add('hidden');
        document.getElementById('workspacePanel').classList.remove('flex');
        document.getElementById('stateWaiting').classList.remove('hidden');
        document.getElementById('stateWaiting').classList.add('flex');
        document.getElementById('notasInput').value = '';
    }

    function startTimer() {
        if(timerInterval) clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            secondsElapsed++;
            actualizarRelojVisual();
        }, 1000);
    }

    function actualizarRelojVisual() {
        const min = Math.floor(secondsElapsed / 60).toString().padStart(2, '0');
        const sec = (secondsElapsed % 60).toString().padStart(2, '0');
        const display = document.getElementById('timerDisplay');
        if(!display.classList.contains('blink')) {
            if (isNaN(secondsElapsed)) display.textContent = "00:00";
            else display.textContent = `${min}:${sec}`;
        }
    }

    function mostrarDerivacion() { document.getElementById('modalDerivar').classList.remove('hidden'); }
    async function confirmarDerivacion() {
        const motivo = document.getElementById('motivoDerivacion').value;
        if(!motivo) return alert("Ingrese motivo");
        const res = await fetch('/api/tickets/derivar', {
            method: 'POST', headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ ticketId: currentTicketId, motivo, usuarioId: currentUser._id })
        });
        if(res.ok) {
            alert("Derivado a Jefatura");
            document.getElementById('modalDerivar').classList.add('hidden');
            mostrarEstadoLibre();
        }
    }

    function escapeHtml(text) { if (!text) return ""; return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;").replace(/\n/g, "\\n"); }
    function abrirModalClave() { document.getElementById('modalClave').classList.remove('hidden'); }
    async function guardarNuevaClave() {
        const actual = document.getElementById('passActual').value;
        const nueva = document.getElementById('passNueva').value;
        if(!actual || !nueva) return alert("Complete los campos");
        fetch('/api/usuarios/cambiar-password', {
            method: 'POST', headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ usuarioId: currentUser._id, actual, nueva })
        }).then(r=>r.json()).then(d=>{
            if(d.success){ alert("OK"); document.getElementById('modalClave').classList.add('hidden'); }
            else alert(d.msg);
        });
    }
</script>
</body>
