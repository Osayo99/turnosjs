            </video>
            
            <div id="callOverlay" class="hidden absolute inset-0 bg-blue-600/95 flex-col items-center justify-center z-30 transition-all duration-300">
                <p class="text-2xl font-bold uppercase tracking-[0.5em] mb-4 text-white animate-fade-in-down">Turno Actual</p>
