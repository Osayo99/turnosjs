            <div class="space-y-2 bg-gray-50 p-3 rounded-lg border border-gray-200 max-h-60 overflow-y-auto" id="skillsContainer">
                </div>

            <div class="flex gap-2 mt-6 justify-end pt-4 border-t">
                <button onclick="document.getElementById('modalEditarUsuario').classList.add('hidden')" class="text-gray-500 text-sm font-bold px-3">Cancelar</button>
                <button onclick="guardarEdicionUsuario()" class="bg-blue-600 text-white text-sm font-bold px-4 py-2 rounded-lg hover:bg-blue-700">Guardar Cambios</button>
            </div>
        </div>
    </div>

    <script>
        const sucursalId = localStorage.getItem('anda_sucursal_id');
        const currentUser = JSON.parse(sessionStorage.getItem('anda_user'));
        let socket = null, currentTicketId = null, timerInterval = null;
        
        if(!sucursalId || !currentUser || currentUser.rol !== 'jefe_sucursal') window.location.href = '/ventanilla.html';
        document.getElementById('userName').textContent = currentUser.nombre;
        
        (async () => {
            try {
                const res = await fetch(`/api/sucursales/${sucursalId}`);
                const data = await res.json();
                document.getElementById('sucursalDisplay').textContent = data.nombre;
                cargarDatosDashboard(); 
                cargarPersonal(); 
                buscarHistorial(true);
            } catch(e) { console.error("Error init:", e); }
        })();

        socket = io(); 
        socket.emit('unirse_sucursal', sucursalId);
        ['cola_actualizada', 'ticket_llamado', 'ticket_finalizado'].forEach(evt => socket.on(evt, cargarDatosDashboard));
        
        setInterval(actualizarTimersAgentes, 1000);

        async function cargarDatosDashboard() {
            if(currentTicketId) return;
            try {
                const res = await fetch(`/api/tickets/jefatura/${sucursalId}`);
                const data = await res.json();
                
                document.getElementById('statTotal').textContent = data.stats.total;
                document.getElementById('statPendientes').textContent = data.stats.pendientes;
                document.getElementById('statAtendidos').textContent = data.stats.atendidos;
                document.getElementById('statDerivados').textContent = data.stats.derivados;
                
                renderChart(data.conteoPorTipo); 
                renderVentanillas(data.estadoVentanillas); 
                renderColaMonitor(data.colaEspera); 
                renderDerivados(data.colaDerivados);
            } catch(e) { console.error("Error dashboard", e); }
        }

        function renderVentanillas(agentes) { 
            const grid = document.getElementById('gridVentanillas');
            
            if (!agentes || !agentes.length) {
                grid.innerHTML = '<p class="text-gray-400 text-sm col-span-3 text-center py-4">Sin agentes activos.</p>';
                return;
            }
            
            grid.innerHTML = agentes.map(x => {
                const ocupado = x.estado === 'ocupado';
                const tData = x.ticket || {}; 
                const startTime = tData.inicio ? new Date(tData.inicio).getTime() : 0;

                return `
                <div class="bg-white rounded-xl border-l-4 ${ocupado ? 'border-green-500' : 'border-gray-300'} shadow-sm overflow-hidden relative group hover:shadow-md transition-shadow">
                    
                    <div class="${ocupado ? 'bg-green-100' : 'bg-gray-100'} px-4 py-2 flex justify-between items-center border-b border-gray-200">
                        <span class="font-bold text-xs text-gray-700 uppercase">Ventanilla ${x.numero || '?'}</span>
                        <span class="text-[10px] font-black ${ocupado ? 'text-green-800' : 'text-gray-500'}">${ocupado ? 'ATENDIENDO' : 'DISPONIBLE'}</span>
                    </div>
                    
                    <div class="p-4">
                        <p class="font-bold text-blue-900 truncate mb-2" title="${x.nombre}">${x.nombre}</p>
                        
                        ${ocupado ? `
                            <div class="flex justify-between items-end border-t border-gray-100 pt-2">
                                <div>
                                    <span class="text-3xl font-black text-gray-800 block leading-none">${tData.codigo || '--'}</span>
                                    <span class="text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-bold mt-1 inline-block">${tData.tipo || ''}</span>
                                </div>
                                <div class="text-right">
                                    <p class="text-[10px] text-gray-400 font-bold uppercase">TIEMPO</p>
                                    <p class="font-mono text-xl font-bold text-gray-700 agent-timer" data-start="${startTime}">00:00</p>
                                </div>
                            </div>
                        ` : `
                            <div class="h-12 flex items-center justify-center border border-dashed border-gray-200 rounded-lg">
                                <p class="text-xs text-gray-400 italic">Esperando...</p>
                            </div>
                        `}
                    </div>
                </div>`;
            }).join(''); 
        }

        function actualizarTimersAgentes() { 
            const now = Date.now(); 
            document.querySelectorAll('.agent-timer').forEach(el => { 
                const start = parseInt(el.getAttribute('data-start')); 
                
                if (start && start > 0) {
                    const diff = Math.floor((now - start) / 1000);
                    
                    if (diff >= 0) {
                        const min = Math.floor(diff / 60).toString().padStart(2,'0');
                        const sec = (diff % 60).toString().padStart(2,'0');
                        
                        if(diff >= 3600) {
                            const h = Math.floor(diff / 3600).toString().padStart(2,'0');
                            const m = Math.floor((diff % 3600) / 60).toString().padStart(2,'0');
                            el.textContent = `${h}:${m}:${sec}`;
                        } else {
                            el.textContent = `${min}:${sec}`;
                        }
                        
                        if(diff > 300) el.classList.add('text-red-600');
                        else el.classList.remove('text-red-600');
                    }
                } else {
                    el.textContent = "00:00"; 
                }
            }); 
        }

        function renderChart(d) { document.getElementById('chartTipos').innerHTML = !d.length ? '<p class="text-xs text-gray-400 italic">Sin datos.</p>' : d.map(x=>`<div class="flex items-center gap-2 text-xs"><span class="w-20 font-bold text-gray-600 truncate">${x._id}</span><div class="flex-grow bg-gray-100 rounded-full h-4 overflow-hidden"><div class="bg-blue-500 h-full rounded-full" style="width: ${(x.count/Math.max(...d.map(v=>v.count)))*100}%"></div></div><span class="font-bold text-blue-900 w-6 text-right">${x.count}</span></div>`).join(''); }
        function renderColaMonitor(c) { document.getElementById('listaColaMonitor').innerHTML = c.length ? c.map(t=>`<div class="flex justify-between border-b border-gray-700 pb-1 mb-1"><span class="font-bold text-lg">${t.codigo}</span><span class="text-[10px] text-gray-400">${t.tipoTramite}</span></div>`).join('') : '<p class="text-gray-500 text-xs italic">Vacío.</p>'; }
        function renderDerivados(l) { document.getElementById('listaDerivados').innerHTML = !l.length ? `<div class="text-center p-6 text-gray-400 bg-white rounded-xl border border-dashed text-sm">Sin pendientes.</div>` : l.map(t=>`<div class="bg-white p-4 rounded-xl shadow-sm border-l-4 border-purple-500 flex justify-between items-center"><div><div class="flex items-center gap-2 mb-1"><span class="text-xl font-black text-blue-900">${t.codigo}</span><span class="bg-blue-50 text-blue-600 text-[10px] font-bold px-2 rounded">${t.tipoTramite}</span></div><p class="text-xs text-gray-600"><b>Motivo:</b> ${t.motivoDerivacion}</p></div><button onclick="iniciarAtencionJefe('${t._id}', '${t.codigo}', '${t.tipoTramite}', '${t.documentoCliente||''}')" class="bg-purple-600 text-white px-4 py-2 rounded-lg font-bold text-xs hover:bg-purple-700">ATENDER</button></div>`).join(''); }

        async function buscarHistorial(i=false) {
            let q="",s="",e=""; if(!i){q=document.getElementById('hSearchQuery').value; s=document.getElementById('hDateStart').value; e=document.getElementById('hDateEnd').value;} else { s=new Date().toISOString().split('T')[0]; document.getElementById('hDateStart').value=s; document.getElementById('hDateEnd').value=s; e=s; }
            const tb=document.getElementById('tablaHistorial'); tb.innerHTML=`<tr><td colspan="6" class="p-8 text-center text-gray-400 animate-pulse">Buscando...</td></tr>`;
            try {
                const res = await fetch(`/api/tickets/historial/${sucursalId}?${new URLSearchParams({busqueda:q, fechaInicio:s, fechaFin:e})}`);
                const reg = await res.json();
                if(!reg.length) return tb.innerHTML=`<tr><td colspan="6" class="p-8 text-center text-gray-400 italic">No se encontraron tickets.</td></tr>`;
                tb.innerHTML = reg.map(t=>`<tr class="hover:bg-slate-50 border-b border-gray-100 last:border-0 transition-colors"><td class="p-4"><div class="flex items-center gap-2"><span class="font-bold text-lg text-gray-800">${t.codigo}</span>${t.esPrioritario?'<span class="text-red-500 font-bold ml-1">★</span>':''}</div><div class="text-[10px] uppercase font-bold text-gray-400">${t.tipoTramite}</div></td><td class="p-4 text-xs text-gray-500 font-mono">${new Date(t.creadoEn).toLocaleString()}</td><td class="p-4 text-sm font-bold text-blue-600">${t.documentoCliente||'N/A'}</td><td class="p-4 text-xs"><div class="font-bold text-gray-700">${t.ventanillaAtendio?.nombre||'Pendiente'}</div><div class="text-[9px] text-gray-400 uppercase">${t.ventanillaAtendio?.rol||''}</div></td><td class="p-4 text-sm text-gray-600 max-w-xs break-words">${t.notasAtencion?`"${t.notasAtencion}"`:'--'} ${t.motivoDerivacion?`<div class="mt-1 text-xs text-purple-500 font-bold">Derivado: ${t.motivoDerivacion}</div>`:''}</td><td class="p-4 text-right"><span class="inline-block px-3 py-1 rounded border text-[10px] font-bold uppercase tracking-wider ${t.estado==='finalizado'?'text-green-600 bg-green-50 border-green-200':'text-yellow-600 bg-yellow-50 border-yellow-200'}">${t.estado}</span></td></tr>`).join('');
            } catch(e){}
        }

        async function cargarPersonal() {
            try {
                const res = await fetch(`/api/usuarios/sucursal/${sucursalId}`);
                const users = await res.json();
                document.getElementById('listaPersonalBody').innerHTML = users.map(u => {
                    let skillsStr = '<span class="text-gray-400 text-xs">Sin asignar</span>';
                    
                    if(u.skills && u.skills.length > 0) {
                        const sorted = u.skills.sort((a,b) => a.prioridad - b.prioridad);
                        skillsStr = sorted.map(s => {
                            let color = 'bg-gray-100 text-gray-600';
                            if(s.prioridad === 1) color = 'bg-blue-100 text-blue-700 font-bold';
                            else if(s.prioridad === 2) color = 'bg-blue-50 text-blue-600';
                            return `<span class="${color} text-[9px] px-1.5 py-0.5 rounded border border-blue-50" title="Prioridad ${s.prioridad}">${s.tipo.substring(0,3)}:${s.prioridad}</span>`;
                        }).join(' ');
                    }

                    const uData = JSON.stringify(u).replace(/"/g, '&quot;');
                    const botonEliminar = (u._id !== currentUser._id) 
                        ? `<button onclick="eliminarEjecutivo('${u._id}', '${u.nombre}')" class="text-red-400 hover:text-red-600 text-xs font-bold bg-red-50 hover:bg-red-100 px-2 py-1 rounded flex-shrink-0" title="Eliminar Usuario">🗑️</button>` 
                        : `<span class="w-7 inline-block flex-shrink-0"></span>`;

                    return `<tr class="hover:bg-gray-50 transition-colors">
                        <td class="p-3 font-medium text-gray-800 align-middle">${u.nombre}</td>
                        <td class="p-3 text-gray-500 font-mono text-xs align-middle">${u.username}</td>
                        <td class="p-3 align-middle"><span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-[10px] uppercase font-bold">${u.rol}</span></td>
                        <td class="p-3 font-bold text-gray-700 align-middle">${u.numeroVentanilla||'-'}</td>
                        <td class="p-3 align-middle">
                            <div class="flex gap-1 flex-wrap items-center">${skillsStr}</div>
                        </td>
                        <td class="p-3 align-middle">
                            <div class="flex justify-end items-center gap-1">
                                <button onclick="abrirModalEditar(${uData})" class="text-blue-500 hover:text-blue-700 text-xs font-bold bg-blue-50 hover:bg-blue-100 px-2 py-1 rounded flex-shrink-0" title="Editar">✏️</button>
                                <button onclick="resetearPassword('${u._id}', '${u.nombre}')" class="text-yellow-600 hover:text-yellow-700 text-xs font-bold bg-yellow-50 hover:bg-yellow-100 px-2 py-1 rounded flex-shrink-0" title="Reset Clave">🔑</button>
                                ${botonEliminar}
                            </div>
                        </td>
                    </tr>`;
                }).join('');
            } catch(e) {}
        }

        function abrirModalEditar(u) { 
            document.getElementById('modalEditarUsuario').classList.remove('hidden'); 
            document.getElementById('editUserId').value = u._id; 
            document.getElementById('editUserNombre').value = u.nombre; 
            document.getElementById('editUserUsername').value = u.username; 
            document.getElementById('editUserVent').value = u.numeroVentanilla || 0; 
            
            const tiposPosibles = ['PAGOS', 'CONSULTAS', 'RECLAMOS', 'NUEVOS'];
            const container = document.getElementById('skillsContainer');
            container.innerHTML = '';

            tiposPosibles.forEach(tipo => {
                const skillActual = u.skills ? u.skills.find(s => s.tipo === tipo) : null;
                const valorActual = skillActual ? skillActual.prioridad : 0;

                container.innerHTML += `
                <div class="flex justify-between items-center text-sm p-2 hover:bg-white rounded transition-colors border-b border-gray-100 last:border-0">
                    <span class="font-medium text-gray-700">${tipo}</span>
                    <select class="border border-gray-300 rounded text-xs p-1.5 outline-none focus:border-blue-500 skill-selector bg-white" data-type="${tipo}">
                        <option value="0" ${valorActual === 0 ? 'selected' : ''}>⛔ No atiende</option>
                        <option value="1" ${valorActual === 1 ? 'selected' : ''} class="font-bold text-blue-600">★ Prioridad 1 (Alta)</option>
                        <option value="2" ${valorActual === 2 ? 'selected' : ''}>Prioridad 2 (Media)</option>
                        <option value="3" ${valorActual === 3 ? 'selected' : ''}>Prioridad 3 (Baja)</option>
                    </select>
                </div>`;
            });
        }

        async function guardarEdicionUsuario() { 
            const id = document.getElementById('editUserId').value; 
            const nombre = document.getElementById('editUserNombre').value;
            const username = document.getElementById('editUserUsername').value;
            const ventanilla = document.getElementById('editUserVent').value; 
            
            if(!nombre || !username) return alert("⚠️ Nombre y Usuario son obligatorios");

            const selects = document.querySelectorAll('.skill-selector');
            const skills = [];

            selects.forEach(sel => {
                const prioridad = parseInt(sel.value);
                if (prioridad > 0) {
                    skills.push({ tipo: sel.getAttribute('data-type'), prioridad: prioridad });
                }
            });

            try { 
                const res = await fetch('/api/usuarios/actualizar', { 
                    method: 'POST', 
                    headers: {'Content-Type':'application/json'}, 
                    body: JSON.stringify({ id, nombre, username, skills, numeroVentanilla: ventanilla }) 
                }); 
                
                const data = await res.json();
                if(data.success) { 
                    alert("✅ Usuario actualizado"); 
                    document.getElementById('modalEditarUsuario').classList.add('hidden'); 
                    cargarPersonal(); 
                } else {
                    alert("❌ " + (data.msg || "Error al actualizar")); 
                }
            } catch(e) { alert("Error de conexión"); } 
        }

        async function eliminarEjecutivo(id, nombre) {
            if(confirm(`⚠️ ¿Estás seguro de eliminar al usuario ${nombre}?`)) {
                try {
                    const res = await fetch(`/api/usuarios/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    
                    if(data.success) {
                        alert("✅ Usuario eliminado exitosamente");
                        cargarPersonal();
                    } else {
                        alert("❌ " + (data.msg || "Error al eliminar usuario"));
                    }
                } catch(e) {
                    alert("❌ Error de comunicación con el servidor");
                }
            }
        }

        function subirVideo() { 
            const input = document.getElementById('videoInput');
            const f = input.files[0]; 
            
            if(!f) return alert("⚠️ Por favor, seleccione un archivo de video primero.");

            const btn = document.getElementById('btnSubirVideo');
            const progressContainer = document.getElementById('progressContainer');
            const progressBar = document.getElementById('progressBar');
            const progressText = document.getElementById('progressText');

            btn.disabled = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');
            btn.textContent = "SUBIENDO...";
            progressContainer.classList.remove('hidden');
            progressText.classList.remove('hidden');
            progressBar.style.width = '0%';
            progressText.textContent = '0%';

            const fd = new FormData(); 
            fd.append('videoFile', f); 
            fd.append('sucursalId', sucursalId); 
            const xhr = new XMLHttpRequest();
            xhr.upload.addEventListener("progress", (event) => {
                if (event.lengthComputable) {
                    const percentComplete = Math.round((event.loaded / event.total) * 100);
                    progressBar.style.width = percentComplete + '%';
                    progressText.textContent = percentComplete + '%';
                }
            });
            xhr.addEventListener("load", () => {
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                btn.textContent = "SUBIR VIDEO";
                
                if (xhr.status >= 200 && xhr.status < 300) {
                    try {
                        const data = JSON.parse(xhr.responseText);
                        if(data.success) {
                            alert("✅ Video subido y configurado correctamente.");
                            input.value = "";
                            setTimeout(() => {
                                progressContainer.classList.add('hidden');
                                progressText.classList.add('hidden');
                            }, 1000);
                        } else {
                            alert("❌ Error: " + (data.msg || "No se pudo subir."));
                        }
                    } catch(e) {
                        alert("✅ Subido (El servidor no devolvió JSON).");
                    }
                } else {
                    alert("❌ Error del servidor al intentar subir el archivo.");
                }
            });
            xhr.addEventListener("error", () => {
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                btn.textContent = "SUBIR VIDEO";
                alert("❌ Error de conexión al servidor.");
            });
            xhr.open("POST", "/api/upload-video", true);
            xhr.send(fd);
        }
        
        async function crearEjecutivo() { const n=document.getElementById('newEjecName').value, u=document.getElementById('newEjecUser').value, p=document.getElementById('newEjecPass').value, v=document.getElementById('newEjecVent').value; if(!n||!u||!p||!v)return alert("Datos incompletos"); try{ const res=await fetch('/api/usuarios/crear', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({nombre:n, username:u, password:p, sucursalId, rol:'ejecutivo', numeroVentanilla:v, skills:[]})}); if((await res.json()).success){ alert("Creado"); cargarPersonal(); document.getElementById('newEjecName').value=''; document.getElementById('newEjecUser').value=''; document.getElementById('newEjecPass').value=''; document.getElementById('newEjecVent').value=''; } else alert("Error"); }catch(e){alert("Error");} }
        async function resetearPassword(id, n) { const p=prompt(`Nueva clave para ${n}:`); if(p) fetch('/api/usuarios/admin-reset-password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({targetUserId:id, nuevaPassword:p})}).then(r=>r.ok?alert("OK"):alert("Error")); }
        function abrirModalCambioClave(){document.getElementById('modalCambioClave').classList.remove('hidden');}
        async function guardarMiClave(){ const o=document.getElementById('ownPassOld').value, n=document.getElementById('ownPassNew').value; if(o&&n) fetch('/api/usuarios/cambiar-password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({usuarioId:currentUser._id, actual:o, nueva:n})}).then(r=>r.json()).then(d=>d.success?(alert("OK"),document.getElementById('modalCambioClave').classList.add('hidden')):alert(d.msg)); }
        async function iniciarAtencionJefe(i,c,t,d){if(confirm("¿Atender?")){fetch('/api/tickets/atender-derivado',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ticketId:i,usuarioId:currentUser._id})}); currentTicketId=i; document.getElementById('viewDashboard').classList.add('hidden'); document.getElementById('viewWorkspace').classList.remove('hidden'); document.getElementById('wkTicketCodigo').textContent=c; document.getElementById('wkTicketTipo').textContent=t; document.getElementById('wkDui').textContent=`DUI: ${d}`; secondsElapsed=0; if(timerInterval)clearInterval(timerInterval); timerInterval=setInterval(()=>{secondsElapsed++;document.getElementById('wkTimer').textContent=new Date(secondsElapsed*1000).toISOString().substr(14,5)},1000);}}
        async function finalizarAtencionJefe(){if(confirm("¿Finalizar?")){fetch('/api/tickets/finalizar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ticketId:currentTicketId,notas:document.getElementById('wkNotas').value,tiempoTotal:secondsElapsed})}); cancelarAtencionJefe(); cargarDatosDashboard();}}
        function cancelarAtencionJefe(){document.getElementById('viewWorkspace').classList.add('hidden'); document.getElementById('viewDashboard').classList.remove('hidden'); clearInterval(timerInterval); currentTicketId=null;}
        function logout(){sessionStorage.removeItem('anda_user'); window.location.href='/ventanilla.html';}
    </script>
</body>
</html>
</file>

<file path="public/kiosco.html">
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kiosco de Turnos - ANDA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap');
        body { font-family: 'Outfit', sans-serif; }
        
        .btn-active:active { transform: scale(0.98); }
        .prio-btn { transition: all 0.2s; border: 2px solid #e5e7eb; }
        .prio-selected {
            background-color: #eff6ff !important; 
            border-color: #2563eb !important; 
            color: #1e3a8a !important;
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.1);
        }
        .check-icon { display: none; }
        .prio-selected .check-icon { display: inline-block; }
        @media print {
            body > * { display: none !important; }
            
            #ticketPrint { 
                visibility: visible !important; 
                display: flex !important;
                position: fixed; 
                left: 0; top: 0; width: 100%; height: 100%;
                justify-content: center; align-items: center; 
                background: white; z-index: 9999; margin: 0;
            }
            #ticketPrint * { visibility: visible !important; }
            .hidden { display: none !important; }
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col p-4 select-none">

    <header class="flex justify-between items-center mb-6 py-2">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold text-xl">A</div>
            <div>
                <h1 class="text-xl font-bold text-blue-900 leading-tight">Bienvenido a ANDA</h1>
                <p class="text-blue-500 text-xs">Sistema de Atención</p>
            </div>
        </div>
        <div class="text-right">
            <p id="reloj" class="text-lg font-bold text-blue-900">--:--</p>
        </div>
    </header>

    <div class="bg-white p-4 rounded-2xl shadow-sm border border-blue-100 mb-4">
        <label class="block text-xs font-bold text-gray-400 uppercase mb-2 ml-1">1. Ingrese su Documento</label>
        <div class="flex flex-col md:flex-row gap-3">
            <div class="w-full md:w-1/3">
                <select id="docType" onchange="cambiarMascara()" class="w-full h-14 px-4 bg-gray-50 border-2 border-blue-50 rounded-xl text-blue-900 font-bold outline-none focus:border-blue-500 appearance-none cursor-pointer">
                    <option value="DUI">💧 DUI</option>
                    <option value="NIT">📄 NIT</option>
                    <option value="PASAPORTE">✈️ Pasaporte</option>
                    <option value="OTRO">👤 Otro</option>
                </select>
            </div>
            <div class="w-full md:w-2/3 relative">
                <input type="text" id="documentoInput" placeholder="00000000-0" 
                    class="w-full h-14 px-4 bg-gray-50 border-2 border-blue-50 rounded-xl text-xl font-bold text-blue-900 outline-none focus:border-blue-500 uppercase placeholder-gray-300 tracking-wider">
            </div>
        </div>
        <p id="docHint" class="text-[10px] text-gray-400 mt-2 ml-1">Formato: 00000000-0</p>
    </div>

    <div class="mb-6">
        <label class="block text-xs font-bold text-gray-400 uppercase mb-2 ml-1">2. Tipo de Atención</label>
        <div class="grid grid-cols-2 gap-4">
            
            <button id="btnNormal" onclick="setPrioridad('normal')" class="prio-btn prio-selected bg-white rounded-xl p-4 flex flex-col items-center justify-center gap-1">
                <span class="text-2xl">👤</span>
                <span class="text-sm font-bold">Atención General</span>
            </button>

            <button id="btnPrioridad" onclick="setPrioridad('prioridad')" class="prio-btn bg-white rounded-xl p-4 flex flex-col items-center justify-center gap-1">
                <div class="flex gap-1 text-2xl">
                    <span>🤰</span><span>👴</span><span>♿</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-sm font-bold">Atención Prioritaria</span>
                    <span class="check-icon text-blue-600 font-bold">✓</span>
                </div>
            </button>
        </div>
    </div>

    <div class="flex-grow">
        <label class="block text-xs font-bold text-gray-400 uppercase mb-2 ml-1">3. Seleccione Trámite para Imprimir</label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 h-full pb-8">
            <button onclick="generarTicket('CONSULTAS', this)" class="btn-active bg-white border-2 border-blue-50 hover:border-blue-500 hover:bg-blue-50 p-6 rounded-2xl shadow-sm transition-all group flex items-center gap-4 text-left">
                <div class="bg-blue-100 text-blue-600 w-12 h-12 rounded-full flex items-center justify-center text-2xl">📋</div>
                <div><h3 class="text-lg font-black text-blue-900">Consultas</h3><p class="text-xs text-blue-400">Info general</p></div>
            </button>
            <button onclick="generarTicket('PAGOS', this)" class="btn-active bg-white border-2 border-blue-50 hover:border-green-500 hover:bg-green-50 p-6 rounded-2xl shadow-sm transition-all group flex items-center gap-4 text-left">
                <div class="bg-green-100 text-green-600 w-12 h-12 rounded-full flex items-center justify-center text-2xl">💰</div>
                <div><h3 class="text-lg font-black text-blue-900">Pagos</h3><p class="text-xs text-green-500">Colecturía</p></div>
            </button>
            <button onclick="generarTicket('RECLAMOS', this)" class="btn-active bg-white border-2 border-blue-50 hover:border-orange-500 hover:bg-orange-50 p-6 rounded-2xl shadow-sm transition-all group flex items-center gap-4 text-left">
                <div class="bg-orange-100 text-orange-600 w-12 h-12 rounded-full flex items-center justify-center text-2xl">⚠️</div>
                <div><h3 class="text-lg font-black text-blue-900">Reclamos</h3><p class="text-xs text-orange-400">Quejas</p></div>
            </button>
            <button onclick="generarTicket('NUEVOS', this)" class="btn-active bg-white border-2 border-blue-50 hover:border-purple-500 hover:bg-purple-50 p-6 rounded-2xl shadow-sm transition-all group flex items-center gap-4 text-left">
                <div class="bg-purple-100 text-purple-600 w-12 h-12 rounded-full flex items-center justify-center text-2xl">💧</div>
                <div><h3 class="text-lg font-black text-blue-900">Nuevos Servicios</h3><p class="text-xs text-purple-400">Factibilidad</p></div>
            </button>
        </div>
    </div>

    <div id="ticketPrint" class="hidden flex-col items-center justify-center text-center p-8 bg-white h-screen w-screen">
        <h2 class="text-4xl font-black mb-2 text-black">ANDA</h2>
        
        <div id="printPrioridad" class="hidden border-2 border-black px-4 py-1 mb-4 rounded-lg">
            <p class="text-xl font-bold uppercase text-black">★ PRIORIDAD ★</p>
        </div>
        
        <p class="text-sm uppercase text-black">Su turno es:</p>
        <h1 id="printNumero" class="text-9xl font-black my-6 text-black">--</h1>
        <p id="printTramite" class="text-2xl font-bold uppercase mb-8 text-black">--</p>
        <p class="text-xs text-black">Por favor espere su llamado.</p>
        <p id="printFecha" class="text-[10px] mt-2 text-black"></p>
    </div>

    <script>
        const sucursalId = localStorage.getItem('anda_sucursal_id');
        let esPrioritario = false; 

        if (!sucursalId) window.location.href = '/';

        setInterval(() => document.getElementById('reloj').textContent = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}), 1000);
        const inputDoc = document.getElementById('documentoInput');
        const selectDoc = document.getElementById('docType');
        const hintDoc = document.getElementById('docHint');
        function cambiarMascara() {
            inputDoc.value = ''; 
            const tipo = selectDoc.value;
            
            if (tipo === 'DUI') {
                inputDoc.placeholder = '00000000-0';
                inputDoc.maxLength = 10;
                hintDoc.textContent = 'Formato: 00000000-0';
            } else if (tipo === 'NIT') {
                inputDoc.placeholder = '0000-000000-000-0';
                inputDoc.maxLength = 17;
                hintDoc.textContent = 'Formato: 0000-000000-000-0';
            } else {
                inputDoc.placeholder = 'Número de documento';
                inputDoc.maxLength = 20;
                hintDoc.textContent = 'Ingrese letras o números';
            }
        }

        inputDoc.addEventListener('input', (e) => {
            const tipo = selectDoc.value;
            let v = e.target.value.replace(/\D/g, ''); 

            if (tipo === 'DUI') {
                if (v.length > 9) v = v.slice(0, 9);
                if (v.length > 8) v = v.slice(0, 8) + '-' + v.slice(8);
                e.target.value = v;
            } else if (tipo === 'NIT') {
                if (v.length > 14) v = v.slice(0, 14);
                let formatted = '';
                if(v.length > 0) formatted += v.slice(0,4);
                if(v.length > 4) formatted += '-' + v.slice(4,10);
                if(v.length > 10) formatted += '-' + v.slice(10,13);
                if(v.length > 13) formatted += '-' + v.slice(13,14);
                e.target.value = formatted;
            }
        });
        function setPrioridad(tipo) {
            const btnN = document.getElementById('btnNormal');
            const btnP = document.getElementById('btnPrioridad');
            
            if (tipo === 'prioridad') {
                esPrioritario = true;
                btnP.classList.add('prio-selected');
                btnN.classList.remove('prio-selected');
            } else {
                esPrioritario = false;
                btnN.classList.add('prio-selected');
                btnP.classList.remove('prio-selected');
            }
        }
        async function generarTicket(tipoTramite, btnElement) {
            const documento = inputDoc.value;
            
            if (!documento || documento.length < 5) {
                alert("Por favor ingrese un documento válido.");
                inputDoc.focus();
                return;
            }

            const condiciones = esPrioritario ? ['Prioridad'] : [];

            const originalContent = btnElement.innerHTML;
            btnElement.innerHTML = `<span class="font-bold text-blue-900 animate-pulse">IMPRIMIENDO...</span>`;
            btnElement.disabled = true;

            try {
                const res = await fetch('/api/tickets/crear', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        sucursalId: sucursalId,
                        tipoTramite: tipoTramite,
                        documento: documento,
                        condiciones: condiciones
                    })
                });

                const data = await res.json();

                if (data.success) {
                    imprimirTicket(data.ticket);
                    inputDoc.value = '';
                    setPrioridad('normal');
                } else {
                    alert('Error: ' + data.msg);
                }

            } catch (error) { console.error(error); } 
            finally {
                setTimeout(() => {
                    btnElement.innerHTML = originalContent;
                    btnElement.disabled = false;
                }, 1000);
            }
        }

        function imprimirTicket(ticket) {
            document.getElementById('printNumero').textContent = ticket.codigo;
            document.getElementById('printTramite').textContent = ticket.tipoTramite;
            document.getElementById('printFecha').textContent = new Date().toLocaleString();
            
            const boxPrio = document.getElementById('printPrioridad');
            
            if(ticket.esPrioritario) {
                boxPrio.classList.remove('hidden');
                boxPrio.style.display = 'block';
            } else {
                boxPrio.classList.add('hidden');
                boxPrio.style.display = 'none';
            }

            window.print();
        }
    </script>
</body>
</html>
</file>

