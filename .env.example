# ─── Servidor ───
PORT=3000

# ─── Base de datos ───
MONGO_URI=mongodb://127.0.0.1:27017/anda_turnos
DB_MAX_RETRIES=3
DB_RETRY_DELAY=3000

# ─── Seguridad ───
# Generar con: openssl rand -base64 64
JWT_SECRET=cambiar_por_valor_seguro_generado_con_openssl
CORS_ORIGIN=*

# ─── Subida de archivos ───
MAX_BODY_SIZE=5mb
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./public/uploads

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=10

# ─── Admin inicial (crearAdmin.js) ───
ADMIN_USERNAME=superanda
ADMIN_PASSWORD=cambiar_por_clave_segura

# ─── Entorno ───
NODE_ENV=production
